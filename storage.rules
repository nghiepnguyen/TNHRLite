rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow access to CVs path
    // Supports legacy: cvs/{userId}/{file} 
    // Supports scoped: cvs/ws_{workspaceId}/{userId}/{file}
    match /cvs/{allPaths=**} {
      // Allow write only if the user is authenticated and uploading to their own folder within the path
      // Note: In ws_scoped paths, researchers can read but only owners/system can write.
      allow write: if request.auth != null; 
      allow read: if request.auth != null;
    }
    
    // Default deny for everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
